\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces GAT attention weights partitioned by party alignment. (a) Same-party connections receive orders of magnitude more attention than cross-party ties across all congresses. (b) The ratio of same-party to cross-party attention exceeds 100 in every session.}}{8}{figure.caption.6}\protected@file@percent }
\newlabel{fig:attention}{{4}{8}{GAT attention weights partitioned by party alignment. (a) Same-party connections receive orders of magnitude more attention than cross-party ties across all congresses. (b) The ratio of same-party to cross-party attention exceeds 100 in every session}{figure.caption.6}{}}
