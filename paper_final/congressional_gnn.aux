\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Defection Prediction}{6}{subsection.6.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Defection prediction results on held-out Congresses 115--117 at the 10\% threshold, evaluated with validation-calibrated thresholds (seed=42). Tree-based models substantially outperform graph neural networks on this tabular classification task. The GCN and GAT perform comparably, suggesting that learned attention provides limited advantage over uniform aggregation for this highly partisan network structure.}}{6}{table.caption.3}\protected@file@percent }
\newlabel{tab:model_comparison}{{2}{6}{Defection prediction results on held-out Congresses 115--117 at the 10\% threshold, evaluated with validation-calibrated thresholds (seed=42). Tree-based models substantially outperform graph neural networks on this tabular classification task. The GCN and GAT perform comparably, suggesting that learned attention provides limited advantage over uniform aggregation for this highly partisan network structure}{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Model performance across defection thresholds. Tree-based models (random forests, logistic regression) achieve higher F1 scores across all thresholds, consistent with findings that neural networks often underperform on small tabular datasets \citep  {grinsztajn2022tree}.}}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:model_comparison}{{2}{6}{Model performance across defection thresholds. Tree-based models (random forests, logistic regression) achieve higher F1 scores across all thresholds, consistent with findings that neural networks often underperform on small tabular datasets \citep {grinsztajn2022tree}}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Threshold Sensitivity}{7}{subsection.6.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Threshold sensitivity analysis. Random forests maintain the highest F1 score across all defection thresholds, consistent with their superior performance on this tabular classification task.}}{7}{figure.caption.5}\protected@file@percent }
\newlabel{fig:threshold}{{3}{7}{Threshold sensitivity analysis. Random forests maintain the highest F1 score across all defection thresholds, consistent with their superior performance on this tabular classification task}{figure.caption.5}{}}
